## Sulala Agent — copy to .env and fill in

## Gateway
PORT=2026
HOST=127.0.0.1

## Database (path relative to project root)
DB_PATH=./data/sulala.db



## Gateway auth (optional; if set, require X-Api-Key header or ?api_key=)
# GATEWAY_API_KEY=

## Webhooks (optional; POST on file_event and task_done)
# WEBHOOK_URL=https://your-server.com/webhook
# WEBHOOK_URLS=https://a.com/hook,https://b.com/hook
# WEBHOOK_SECRET=your-secret

# Optional: enable debug logs
DEBUG=1
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Agent run timeout in ms (optional; 0 = no timeout). Request body can override with timeout_ms.
AGENT_TIMEOUT_MS=300000



# Skills dir: subdirs = skills (README.md or SKILL.md). ~ is expanded to your home dir.
SULALA_SKILLS_DIR=~/.sulala/workspace/skills
SULALA_CONFIG_PATH=~/.sulala/config.json
# Agent workspace root for read_file tool (optional). If set, agent can read files under this path only.
AGENT_WORKSPACE_ROOT=.
SULALA_WORKSPACE_SKILLS_MY_DIR=~/.sulala/workspace/skills/my

## Single URL for skills registry (list + install). When serving as hub, base for skill links is derived from this.
## SKILLS_REGISTRY_URL=https://hub.sulala.ai
SKILLS_REGISTRY_URL=https://hub.sulala.ai

# http://localhost:3004


## log skill environment variables
SULALA_LOG_SKILL_ENV=1 



## enable pi coding-agent runtime
AGENT_USE_PI=1

## max context tokens for the agent
AGENT_MAX_CONTEXT_TOKENS=70000


## shared memory key for shared memory across sessions
AGENT_SHARED_MEMORY_KEY=1

# -----------------------------------------------------------------------------
# MCP servers (optional alternative to Integrations)
# -----------------------------------------------------------------------------
# Off by default. Configure in Dashboard → Integrations → MCP Servers tab (saved to ~/.sulala/mcp.json),
# or create ~/.sulala/mcp.json manually, or set MCP_SERVERS for automation.
# Add servers (YouTube, Gmail, etc.) and their API keys in the MCP Servers tab; tools appear as mcp_<name>_<tool>.
# MCP_SERVERS=[{"name":"youtube","command":"npx","args":["-y","zubeid-youtube-mcp-server"],"env":{"YOUTUBE_API_KEY":"..."}}]



