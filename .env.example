# Sulala Agent — copy to .env and fill in

# Gateway
PORT=2026
HOST=127.0.0.1

# Database (path relative to project root)
DB_PATH=./data/sulala.db



# Gateway auth (optional; if set, require X-Api-Key header or ?api_key=)
# GATEWAY_API_KEY=

# Webhooks (optional; POST on file_event and task_done)
# WEBHOOK_URL=https://your-server.com/webhook
# WEBHOOK_URLS=https://a.com/hook,https://b.com/hook
# WEBHOOK_SECRET=your-secret

# Optional: enable debug logs
DEBUG=1
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Agent run timeout in ms (optional; 0 = no timeout). Request body can override with timeout_ms.
AGENT_TIMEOUT_MS=300000



# Skills dir: subdirs = skills (README.md or SKILL.md). ~ is expanded to your home dir.
SULALA_SKILLS_DIR=~/.sulala/workspace/skills
SULALA_CONFIG_PATH=~/.sulala/config.json
# Agent workspace root for read_file tool (optional). If set, agent can read files under this path only.
AGENT_WORKSPACE_ROOT=.
SULALA_WORKSPACE_SKILLS_MY_DIR=~/.sulala/workspace/skills/my

# Single URL for skills registry (list + install). When serving as hub, base for skill links is derived from this.
# SKILLS_REGISTRY_URL=https://hub.sulala.ai
SKILLS_REGISTRY_URL=https://hub.sulala.ai

# http://localhost:3004


SULALA_LOG_SKILL_ENV=1 
# When 1, high-risk tools (write_file, run_command, post_to_bluesky) require approval in Dashboard > Pending.
# AGENT_EXECUTION_PREVIEW=1
# For github_repos tool: URL of the integrations service (e.g. http://localhost:1717). Connect GitHub in Dashboard → Integrations first.
# INTEGRATIONS_URL=http://localhost:1717
AGENT_USE_PI=1

# do not use execution preview
# AGENT_EXECUTION_PREVIEW=1


# -----------------------------------------------------------------------------
# Integrations (OAuth connections: GitHub, Gmail, Asana, Facebook, Linear, etc.)
# -----------------------------------------------------------------------------
# Option A — Portal (recommended when using the Portal app): use connections from Portal → API Keys.
# get api key from https://portal.sulala.ai/api-keys and copy it to the .env file PORTAL_API_KEY

PORTAL_GATEWAY_URL=https://portal.sulala.ai/api/gateway
# PORTAL_API_KEY=sk_live_... or sk_test_... (get from https://portal.sulala.ai/api-keys)

# Option B — Direct integrations service: URL of the integrations service (e.g. http://localhost:1717). When set (and portal not set), agent talks to integrations directly. Use for local/single-tenant only.
# INTEGRATIONS_URL=http://localhost:1717


AGENT_MAX_CONTEXT_TOKENS=70000



AGENT_SHARED_MEMORY_KEY=1

# -----------------------------------------------------------------------------
# ChatGPT Apps SDK / MCP OAuth 2.1 (optional)
# -----------------------------------------------------------------------------
# Enable and set when exposing this agent as an MCP resource server for ChatGPT.
# Configure in onboarding (Integrations step) or here. Your IdP (Auth0, Stytch, etc.)
# must support dynamic client registration and PKCE; allowlist redirect URIs:
#   https://chatgpt.com/connector/oauth/{callback_id}
#   https://platform.openai.com/apps-manage/oauth
# MCP_OAUTH_ENABLED=0
# MCP_OAUTH_RESOURCE_URL=https://your-agent.example.com
# MCP_OAUTH_AUTHORIZATION_SERVER=https://tenant.auth0.com
# MCP_OAUTH_SCOPES_SUPPORTED=openid,files:read


