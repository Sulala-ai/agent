# Sulala Agent — copy to .env and fill in. Keep secrets out of git.
#
# Quick start: copy to .env, run the agent. Add AI keys via dashboard onboarding
# (http://localhost:2026 after start) or below. See README for more options.

# -----------------------------------------------------------------------------
# Gateway (required) — 2026 to avoid conflict with common dev servers (3000, 5000, 8080)
# -----------------------------------------------------------------------------
PORT=2026
HOST=127.0.0.1
DB_PATH=./data/sulala.db

# -----------------------------------------------------------------------------
# AI (optional — Ollama works with no key; add keys for OpenAI/Claude/Gemini/OpenRouter)
# Best set via dashboard onboarding; or uncomment and set here:
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GEMINI_API_KEY=   or GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# AI_DEFAULT_PROVIDER=ollama



# OAuth "Connect with Sulala" (dashboard button): register agent in Portal with redirect_uri = http://localhost:2026/api/oauth/callback, then set:
PORTAL_OAUTH_CLIENT_ID=app_33492c8609b38bd1df3e42ab
PORTAL_OAUTH_CLIENT_SECRET=54681b036bc7ca266fb2c1d17a8c35e3ff417ee7332d06db1491d69fae3e711c
DEFAULT_PORTAL_GATEWAY_URL=https://portal.sulala.ai/api/gateway




AGENT_SHARED_MEMORY_KEY=1
