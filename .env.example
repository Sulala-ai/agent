# Sulala Agent — copy to .env and fill in. Keep secrets out of git.
#
# Quick start: copy to .env, run the agent. Add AI keys via dashboard onboarding
# (http://localhost:2026 after start) or below. See README for more options.

# -----------------------------------------------------------------------------
# Gateway (required) — 2026 to avoid conflict with common dev servers (3000, 5000, 8080)
# -----------------------------------------------------------------------------
PORT=2026
HOST=127.0.0.1
DB_PATH=./data/sulala.db

# -----------------------------------------------------------------------------
# AI (optional — Ollama works with no key; add keys for OpenAI/Claude/Gemini/OpenRouter)
# Best set via dashboard onboarding; or uncomment and set here:
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GEMINI_API_KEY=   or GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# AI_DEFAULT_PROVIDER=ollama



# OAuth "Connect with Sulala" (dashboard button): register agent in Portal with redirect_uri = http://localhost:2026/api/oauth/callback, then set:
PORTAL_OAUTH_CLIENT_ID=app_33492c8609b38bd1df3e42ab
PORTAL_OAUTH_CLIENT_SECRET=54681b036bc7ca266fb2c1d17a8c35e3ff417ee7332d06db1491d69fae3e711c
DEFAULT_PORTAL_GATEWAY_URL=https://portal.sulala.ai/api/gateway


# -----------------------------------------------------------------------------
# Agent — configure agent behavior and tools
# -----------------------------------------------------------------------------

AGENT_SHARED_MEMORY_KEY=1


# -----------------------------------------------------------------------------
# Agent — configure agent behavior and tools
# -----------------------------------------------------------------------------
AGENT_MAX_CONTEXT_TOKENS=70000

SULALA_LOG_SKILL_ENV=1 


DEBUG=1
# -----------------------------------------------------------------------------
# Rate limiting — configure rate limiting for the agent
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Agent run timeout in ms (optional; 0 = no timeout). Request body can override with timeout_ms.
AGENT_TIMEOUT_MS=300000



# Skills registry (single URL). Fetch skill list and install from here. When this instance serves the hub, the base URL for skill links is derived from this (origin).
SKILLS_REGISTRY_URL=https://hub.sulala.ai




# Skills dir: subdirs = skills (README.md or SKILL.md). ~ is expanded to your home dir.
SULALA_SKILLS_DIR=~/.sulala/workspace/skills
SULALA_CONFIG_PATH=~/.sulala/config.json
# Agent workspace root for read_file tool (optional). If set, agent can read files under this path only.
AGENT_WORKSPACE_ROOT=.
SULALA_WORKSPACE_SKILLS_MY_DIR=~/.sulala/workspace/skills/my

# Publish to store: optional. Store URL is SKILLS_REGISTRY_URL. API key only if your store requires it (create on store My skills).
# STORE_PUBLISH_API_KEY=
