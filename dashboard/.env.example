# Optional: gateway URL when running dashboard dev server (npm run dev) separately.
# If unset, the app uses the current origin (works when served from the gateway).
# VITE_GATEWAY_URL=http://127.0.0.1:2026
# Optional: API key if gateway has GATEWAY_API_KEY set.
# VITE_GATEWAY_API_KEY=your-key

# Optional: hub/store URL for "From Hub" tab (e.g. http://localhost:3002). Skills from this API can be installed from the UI.
# VITE_SKILLS_REGISTRY_URL=http://localhost:3002

# Optional: integrations service URL for the Integrations page. When the agent has INTEGRATIONS_URL set, the dashboard uses it from the gateway config — you do not need to set this. Only set VITE_INTEGRATIONS_URL if the dashboard runs separately and you are not using the agent's config (e.g. fallback http://localhost:1717).
# VITE_INTEGRATIONS_URL=http://localhost:1717
